# ============================================================
# 酒店客房服务 Agent — 环境变量说明
# ============================================================
# 使用方法:
#   1. 复制此文件为 .env:  cp .env.example .env
#   2. 填入你的真实 API Key
#   3. 启动服务:            python server.py
#
# ⚠️ .env 已在 .gitignore 中排除，不会被提交到 Git。

# ----------------------------------------------------------
# DeepSeek API 配置（必需）
# ----------------------------------------------------------
# 前往 https://platform.deepseek.com/api_keys 创建 API Key
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# DeepSeek API 地址（通常不需要修改）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ----------------------------------------------------------
# 服务器配置（可选）
# ----------------------------------------------------------
# 监听地址，0.0.0.0 表示接受所有网络接口的连接
SERVER_HOST=0.0.0.0

# 监听端口
SERVER_PORT=8000
